{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"Add-Content -Path $env:TEMP\\claude_hook_test.txt -Value '[Stop] Hook fired at $(Get-Date -Format HH:mm:ss)'\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
