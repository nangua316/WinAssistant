<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WinAssistant.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinAssistant">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ButtonOverlayHoverBrush" Color="#0A000000" />
                    <SolidColorBrush x:Key="ButtonOverlayPressedBrush" Color="#19000000" />
                    <!-- MainPage 设置页颜色 — 放在 App 级别确保 RequestedTheme 切换时刷新 -->
                    <SolidColorBrush x:Key="CardBgBrush" Color="#FBFBFD" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#EDEDF0" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1C1C1E" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E6E73" />
                    <SolidColorBrush x:Key="TextDimBrush" Color="#9E9EA2" />
                    <SolidColorBrush x:Key="AccentBlue" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="IconAmber" Color="{ThemeResource SystemAccentColorLight1}" />
                    <SolidColorBrush x:Key="PurpleBrush" Color="{ThemeResource SystemAccentColorDark1}" />
                    <SolidColorBrush x:Key="IconGreen" Color="{ThemeResource SystemAccentColorLight2}" />
                    <SolidColorBrush x:Key="LaunchpadBgBrush" Color="#F0F0F5" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ButtonOverlayHoverBrush" Color="#1AFFFFFF" />
                    <SolidColorBrush x:Key="ButtonOverlayPressedBrush" Color="#33FFFFFF" />
                    <!-- MainPage 设置页颜色 -->
                    <SolidColorBrush x:Key="CardBgBrush" Color="#262B3B" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#2E3447" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F0F5" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A8" />
                    <SolidColorBrush x:Key="TextDimBrush" Color="#7A7A80" />
                    <SolidColorBrush x:Key="AccentBlue" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="IconAmber" Color="{ThemeResource SystemAccentColorLight1}" />
                    <SolidColorBrush x:Key="PurpleBrush" Color="{ThemeResource SystemAccentColorLight3}" />
                    <SolidColorBrush x:Key="IconGreen" Color="{ThemeResource SystemAccentColorLight2}" />
                    <SolidColorBrush x:Key="LaunchpadBgBrush" Color="#1A1A1A" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <DataTemplate x:Key="AppPickerTemplate">
                <Grid Padding="8,4" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Width="36" Height="36"
                           Source="{Binding IconSource}" />
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Name}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="1" Text="{Binding AppPath}"
                                   Opacity="0.5" FontSize="11"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                    </Grid>
                    <Button Grid.Column="2" Content="{Binding AddButtonText}"
                            Command="{Binding AddCommand}"
                            IsEnabled="{Binding IsInteractive}"
                            Style="{StaticResource FlatButtonStyle}"
                            MinWidth="64" MinHeight="28" Padding="10,2"
                            CornerRadius="4" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>
            </DataTemplate>

            <Style x:Key="FlatButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid CornerRadius="{TemplateBinding CornerRadius}">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                        BorderBrush="{ThemeResource ButtonBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{TemplateBinding CornerRadius}" />
                                <Border x:Name="Overlay" Background="Transparent"
                                        CornerRadius="{TemplateBinding CornerRadius}" />
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Overlay.Background" Value="{ThemeResource ButtonOverlayHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Overlay.Background" Value="{ThemeResource ButtonOverlayPressedBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SystemControlDisabledBaseMediumLowBrush}" />
                                                <Setter Target="ContentPresenter.Opacity" Value="0.85" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
