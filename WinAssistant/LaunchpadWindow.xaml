<Window
    x:Class="WinAssistant.LaunchpadWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 透明 Grid + MicaBackdrop 让 Launchpad 使用系统 Mica 背景，与设置窗口一致 -->
    <Grid x:Name="RootGrid" Background="Transparent">
        <!-- ContentScaleHost is what we animate (scale only).
             RootGrid's full-size background allows Mica to show through. -->
        <Grid x:Name="ContentScaleHost" />
    </Grid>
</Window>
