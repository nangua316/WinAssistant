<Window
    x:Class="WinAssistant.LaunchpadWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="{ThemeResource LaunchpadBgBrush}">
        <!-- ContentScaleHost is what we animate (scale only).
             RootGrid's dark background stays full-size at all times. -->
        <Grid x:Name="ContentScaleHost" />
    </Grid>
</Window>
