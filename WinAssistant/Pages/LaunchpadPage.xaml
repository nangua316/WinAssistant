<Page x:Class="WinAssistant.Pages.LaunchpadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:WinAssistant.ViewModels"
      xmlns:helpers="using:WinAssistant.Helpers"
      Background="Transparent"
      KeyDown="OnPageKeyDown">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- ===== Light Theme ===== -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#A0F3F3F3" />
                    <SolidColorBrush x:Key="ControlIdleBrush" Color="#E0F3F3F3" />
                    <SolidColorBrush x:Key="ControlHoverBrush" Color="#0A000000" />
                    <SolidColorBrush x:Key="ControlFocusBrush" Color="#14000000" />
                    <SolidColorBrush x:Key="ControlPressedBrush" Color="#19000000" />

                    <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AccentDimBrush" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AccentStrongBrush" Color="{ThemeResource SystemAccentColor}" />

                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1C1C1E" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#88616161" />
                    <SolidColorBrush x:Key="TextDimBrush" Color="#609E9E9E" />

                    <SolidColorBrush x:Key="ItemIconCircleBrush" Color="#0A000000" />
                    <SolidColorBrush x:Key="ItemFallbackBrush" Color="#88616161" />
                    <SolidColorBrush x:Key="ItemNameBrush" Color="#DD1C1C1E" />

                    <SolidColorBrush x:Key="GridViewItemBackgroundPointerOver" Color="#0A000000" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelected" Color="#14000000" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPointerOver" Color="#19000000" />

                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0A000000" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#14000000" />
                </ResourceDictionary>

                <!-- ===== Dark Theme ===== -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#B02C2C2C" />
                    <SolidColorBrush x:Key="ControlIdleBrush" Color="#D92C2C2C" />
                    <SolidColorBrush x:Key="ControlHoverBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="ControlFocusBrush" Color="#1EFFFFFF" />
                    <SolidColorBrush x:Key="ControlPressedBrush" Color="#33FFFFFF" />

                    <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AccentDimBrush" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AccentStrongBrush" Color="{ThemeResource SystemAccentColor}" />

                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#889E9E9E" />
                    <SolidColorBrush x:Key="TextDimBrush" Color="#607A7A7A" />

                    <SolidColorBrush x:Key="ItemIconCircleBrush" Color="#1AFFFFFF" />
                    <SolidColorBrush x:Key="ItemFallbackBrush" Color="#889E9E9E" />
                    <SolidColorBrush x:Key="ItemNameBrush" Color="#DDFFFFFF" />

                    <SolidColorBrush x:Key="GridViewItemBackgroundPointerOver" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelected" Color="#1EFFFFFF" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPointerOver" Color="#33FFFFFF" />

                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1EFFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

        <!-- Converters -->
        <helpers:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <helpers:BoolToDragOpacityConverter x:Key="BoolToDragOpacityConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:BoolToScaleConverter x:Key="BoolToScaleConverter" />
        <helpers:BoolToDimOpacityConverter x:Key="BoolToDimOpacityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />

        <!-- ===== Pin ToggleButton Style ===== -->
        <Style x:Key="PinToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid CornerRadius="8" Background="Transparent">
                            <Border x:Name="BgBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8" />
                            <FontIcon x:Name="PinIcon"
                                      Glyph="&#xE718;"
                                      FontSize="16"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="BgBorder.Background"
                                                    Value="{ThemeResource ControlHoverBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="BgBorder.Background"
                                                    Value="{ThemeResource ControlPressedBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="BgBorder.Background"
                                                    Value="{ThemeResource AccentDimBrush}" />
                                            <Setter Target="PinIcon.Foreground"
                                                    Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="BgBorder.Background"
                                                    Value="{ThemeResource AccentStrongBrush}" />
                                            <Setter Target="PinIcon.Foreground"
                                                    Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <VisualState.Setters>
                                            <Setter Target="BgBorder.Background"
                                                    Value="{ThemeResource AccentStrongBrush}" />
                                            <Setter Target="PinIcon.Foreground"
                                                    Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Page.Resources>

    <!-- ===== Page Surface (半透明覆盖层，Mica 透出) ===== -->
    <Grid Background="{ThemeResource PageBackgroundBrush}"
          RightTapped="OnPageRightTapped">
        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== Search Bar ===== -->
            <Grid>
                <TextBox x:Name="SearchBox"
                         PlaceholderText="搜索应用..."
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalAlignment="Stretch"
                         Background="{ThemeResource ControlIdleBrush}"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         PlaceholderForeground="{ThemeResource TextDimBrush}"
                         BorderThickness="0"
                         CornerRadius="10"
                         Padding="16,11,50,11"
                         Margin="0,0,48,0"
                         FontSize="14"
                         KeyDown="OnSearchBoxKeyDown" />
                <!-- Pin toggle -->
                <ToggleButton x:Name="PinButton"
                              Click="OnPinToggle"
                              Style="{StaticResource PinToggleButtonStyle}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0"
                              ToolTipService.ToolTip="固定窗口" />
            </Grid>

            <!-- ===== App Grid ===== -->
            <GridView Grid.Row="1"
                      x:Name="AppGrid"
                      ItemsSource="{x:Bind ViewModel.FilteredItems, Mode=OneWay}"
                      CanDragItems="False"
                      AllowDrop="False"
                      CanReorderItems="False"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="OnItemClick"
                      Padding="0,8"
                      KeyDown="OnAppGridKeyDown"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollMode="Enabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="90"
                                       ItemHeight="110" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="MaxWidth" Value="120" />
                        <Setter Property="Clip" Value="{x:Null}" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LaunchpadItemViewModel">
                        <Grid Tag="{x:Bind}"
                              Opacity="{x:Bind IsBeingDragged, Mode=OneWay, Converter={StaticResource BoolToDragOpacityConverter}}"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform
                                    ScaleX="{x:Bind IsBeingDragged, Mode=OneWay, Converter={StaticResource BoolToScaleConverter}}"
                                    ScaleY="{x:Bind IsBeingDragged, Mode=OneWay, Converter={StaticResource BoolToScaleConverter}}" />
                            </Grid.RenderTransform>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Drag target highlight -->
                            <Border Grid.RowSpan="2"
                                    Background="{ThemeResource AccentDimBrush}"
                                    CornerRadius="8"
                                    Visibility="{x:Bind IsDragOverTarget, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!-- Icon area -->
                            <Border Width="84" Height="84"
                                    Background="Transparent"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="{x:Bind ContextMenuText, Mode=OneWay}" Click="OnRemoveItem" />
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <Grid>
                                    <!-- Fallback: circle + letter (non-tools only) -->
                                    <Ellipse Width="52" Height="52"
                                             Fill="{ThemeResource ItemIconCircleBrush}"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             Visibility="{x:Bind IconSource, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}" />
                                    <TextBlock Text="{x:Bind FallbackChar}"
                                               FontSize="22"
                                               Foreground="{ThemeResource ItemFallbackBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Visibility="{x:Bind IconSource, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}" />
                                    <!-- Tool icon glyph inside circle (only when no extracted icon) -->
                                    <TextBlock Text="{x:Bind ToolIconGlyph, Mode=OneWay}"
                                               FontSize="32"
                                               Foreground="{x:Bind ToolIconBrush, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Visibility="{x:Bind ShowToolGlyph, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Extracted app icon (for both tools and regular apps) -->
                                    <Image Source="{x:Bind IconSource, Mode=OneWay}"
                                           Width="52" Height="52"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Visibility="{x:Bind HasIcon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Uninstalled dim overlay -->
                                    <Border Background="#88000000"
                                            Width="52" Height="52"
                                            CornerRadius="26"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Visibility="{x:Bind IsUninstalled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Uninstalled badge -->
                                    <Border Width="18" Height="18"
                                            CornerRadius="9"
                                            Background="#CCE04848"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,2,2"
                                            Visibility="{x:Bind IsUninstalled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <FontIcon Glyph="&#xE711;" FontSize="10"
                                                  Foreground="White"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- App name -->
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind Name}"
                                       Opacity="{x:Bind IsUninstalled, Mode=OneWay, Converter={StaticResource BoolToDimOpacityConverter}}"
                                       Foreground="{ThemeResource ItemNameBrush}"
                                       FontSize="12"
                                       TextAlignment="Center"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Center"
                                       MaxWidth="110"
                                       Margin="0,4,0,0"
                                       ToolTipService.ToolTip="{x:Bind Name}" />
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Drag ghost overlay (on top of everything, ignores hit testing) -->
            <Canvas x:Name="DragCanvas" Grid.Row="1" IsHitTestVisible="False" />

            <!-- ===== Empty State ===== -->
            <StackPanel Grid.Row="1"
                        x:Name="EmptyStatePanel"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE710;"
                          FontSize="40"
                          Foreground="{ThemeResource TextDimBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="启动台还没有应用"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center" />
                <TextBlock Text="点击下方 + 添加应用 按钮添加"
                           Foreground="{ThemeResource TextDimBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ===== No Results ===== -->
            <StackPanel Grid.Row="1"
                        x:Name="NoResultsPanel"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE11A;"
                          FontSize="40"
                          Foreground="{ThemeResource TextDimBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="未找到匹配的应用"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center" />
                <TextBlock Text="尝试其他关键词"
                           Foreground="{ThemeResource TextDimBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ===== Bottom Bar ===== -->
            <Border Grid.Row="2" Margin="0,8,0,0" Padding="0,4"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               Foreground="{ThemeResource TextDimBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <!-- AI 对话按钮（暂隐藏） -->
                    <Button Grid.Column="1"
                            x:Name="AiChatButton"
                            Click="OnAiChatClick"
                            Background="{ThemeResource AccentDimBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,4"
                            MinHeight="30"
                            FontSize="12"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="🤖" FontSize="14" />
                            <TextBlock Text="AI 指令" FontSize="12" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
