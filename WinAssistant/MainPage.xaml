<Page x:Class="WinAssistant.MainPage" x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:WinAssistant.ViewModels"
      xmlns:local="using:WinAssistant"
      Loaded="OnLoaded" Unloaded="OnUnloaded">
    <Page.Resources>
        <SolidColorBrush x:Key="ListViewItemDropIndicatorForeground"
                         Color="#30D9904A" />
        <SolidColorBrush x:Key="AccentBlue" Color="#FF4CC2FF" />
        <SolidColorBrush x:Key="IconGreen" Color="#FF66BB6A" />
        <SolidColorBrush x:Key="IconAmber" Color="#FFFFA726" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Grid Grid.Column="0"
              BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,1,0">
            <ListView x:Name="MenuListView"
                      SelectionMode="Single"
                      SelectedIndex="0"
                      SelectionChanged="OnMenuSelectionChanged"
                      Background="Transparent"
                      Padding="0,16,0,0"
                      BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="Margin" Value="8,2" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="16"
                                  Foreground="{StaticResource AccentBlue}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="常规设置" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE71D;" FontSize="16"
                                  Foreground="{StaticResource IconGreen}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="启动台设置" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE765;" FontSize="16"
                                  Foreground="{StaticResource IconAmber}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="全局快捷键" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE916;" FontSize="16"
                                  Foreground="{StaticResource AccentBlue}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="小工具" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                            </ListView>
        </Grid>

        <!-- Right content -->
        <Grid Grid.Column="1" Padding="24,24,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Dynamic header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock x:Name="TitleText"
                           Text="常规设置"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock x:Name="SubtitleText"
                           Text="设置应用程序的基本选项"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Opacity="0.7" />
            </StackPanel>

            <!-- ===== General panel ===== -->
            <StackPanel x:Name="GeneralPanel" Grid.Row="1" Spacing="16">
                <CheckBox Content="开机自启动"
                          IsChecked="{x:Bind ViewModel.IsAutoStart, Mode=TwoWay}"
                          FontSize="15" />
            </StackPanel>

            <!-- ===== Launchpad panel ===== -->
            <StackPanel x:Name="LaunchpadPanel" Grid.Row="1" Visibility="Collapsed" Spacing="16">
                <StackPanel Spacing="12">
                    <ToggleSwitch x:Name="LaunchpadEnableToggle"
                                  Header="启用启动台"
                                  IsOn="{x:Bind ViewModel.IsLaunchpadEnabled, Mode=TwoWay}" />

                    <!-- Trigger settings, visible when launchpad is enabled -->
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.LaunchpadSettingsVisibility, Mode=OneWay}">

                        <!-- Mouse triggers -->
                        <TextBlock Text="鼠标触发" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <CheckBox Content="按下中键"
                                  IsChecked="{x:Bind ViewModel.IsMouseTriggerMiddle, Mode=TwoWay}" />
                        <CheckBox Content="按下X1键"
                                  IsChecked="{x:Bind ViewModel.IsMouseTriggerX1, Mode=TwoWay}" />
                        <CheckBox Content="按下X2键"
                                  IsChecked="{x:Bind ViewModel.IsMouseTriggerX2, Mode=TwoWay}" />

                        <!-- Keyboard triggers -->
                        <TextBlock Text="键盘触发" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <CheckBox Content="单击Ctrl"
                                  IsChecked="{x:Bind ViewModel.IsKeyboardTriggerSingleCtrl, Mode=TwoWay}" />
                        <CheckBox Content="全局快捷键"
                                  IsChecked="{x:Bind ViewModel.IsKeyboardTriggerGlobalHotKey, Mode=TwoWay}" />

                        <!-- Hotkey display + modify button (visible when global hotkey is checked) -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="28,0,0,0"
                                    Visibility="{x:Bind ViewModel.GlobalHotKeySettingsVisibility, Mode=OneWay}">
                            <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="12,4">
                                <TextBlock Text="{x:Bind ViewModel.LaunchpadHotKeyDisplay, Mode=OneWay}"
                                           FontSize="14" VerticalAlignment="Center" />
                            </Border>
                            <Button Content="修改" Click="OnModifyGlobalHotKeyClick"
                                    Padding="12,4" CornerRadius="4" MinHeight="32" />
                        </StackPanel>

                        <CheckBox Content="Alt + 空格"
                                  IsChecked="{x:Bind ViewModel.IsKeyboardTriggerAltSpace, Mode=TwoWay}" />

                        <Button Content="打开启动台"
                                Click="OnOpenLaunchpadClick"
                                Padding="16,8" CornerRadius="6"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- ===== Hotkey panel ===== -->
            <Grid x:Name="HotkeyPanel" Grid.Row="1" Visibility="Collapsed">
                <Grid>
                    <ListView x:Name="BindingListView"
                          SelectionMode="Single"
                          ItemsSource="{x:Bind ViewModel.Bindings, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:HotKeyBindingViewModel">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0"
                                       Width="36" Height="36"
                                       VerticalAlignment="Center"
                                       Source="{x:Bind IconSource, Mode=OneWay}"
                                       Tag="{x:Bind}"
                                       Loaded="OnIconImageLoaded" />

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{x:Bind Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind AppPath}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </Grid>

                                <Button Grid.Column="2"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.SetHotKeyCommand}"
                                        CommandParameter="{x:Bind}"
                                        MinWidth="110" MinHeight="32"
                                        VerticalAlignment="Center"
                                        Padding="12,4"
                                        CornerRadius="4">
                                    <TextBlock Text="{x:Bind HotKeyDisplayText, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="13" />
                                </Button>

                                <ToggleSwitch Grid.Column="3"
                                              IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                              VerticalAlignment="Center"
                                              Toggled="OnToggleToggled"
                                              Tag="{x:Bind}"
                                              MinWidth="50" />

                                <Button Grid.Column="4"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveBindingCommand}"
                                        CommandParameter="{x:Bind}"
                                        MinWidth="36" MinHeight="36"
                                        VerticalAlignment="Center"
                                        CornerRadius="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                    <StackPanel Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="12"
                                Padding="48,32">
                        <FontIcon Glyph="&#xE710;" FontSize="64" Opacity="0.5"
                                  Foreground="{StaticResource AccentBlue}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="还没有添加快捷键绑定"
                                   FontSize="18" Opacity="0.85"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text='点击下方 "添加应用程序" 按钮开始'
                                   FontSize="13" Opacity="0.5"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===== Tools panel ===== -->
            <Grid x:Name="ToolPanel" Grid.Row="1" Visibility="Collapsed">
                <!-- Tool list sub-view -->
                <ScrollViewer x:Name="ToolListPanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ToolListStack" Spacing="8" Margin="0,0,24,0" />
                </ScrollViewer>
                <!-- Tool settings sub-view (loaded dynamically) -->
                <Grid x:Name="ToolSettingsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button x:Name="ToolSettingsBackButton"
                            Content="← 返回工具列表"
                            Click="OnToolSettingsBack"
                            Background="Transparent"
                            Padding="0,0,0,12"
                            CornerRadius="4"
                            HorizontalAlignment="Left" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="ToolSettingsContent" />
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Add application button (only visible on hotkey tab) -->
            <Button x:Name="AddAppButton" Grid.Row="2"
                    Visibility="Collapsed"
                    Command="{x:Bind ViewModel.AddApplicationCommand}"
                    Margin="0,12,0,0"
                    Padding="16,8"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="添加应用程序" />
                </StackPanel>
            </Button>

            <!-- Status message -->
            <TextBlock Grid.Row="3"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Margin="0,8,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.5" />
        </Grid>
    </Grid>
</Page>
