<Page x:Class="WinAssistant.MainPage" x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:WinAssistant.ViewModels"
      xmlns:local="using:WinAssistant"
      Loaded="OnLoaded" Unloaded="OnUnloaded">
    <Page.Resources>
        <SolidColorBrush x:Key="ListViewItemDropIndicatorForeground"
                         Color="#30D9904A" />
        <SolidColorBrush x:Key="AccentBlue" Color="#FF4CC2FF" />
        <SolidColorBrush x:Key="IconGreen" Color="#FF66BB6A" />
        <SolidColorBrush x:Key="IconAmber" Color="#FFFFA726" />
        <SolidColorBrush x:Key="PurpleBrush" Color="#FF8B5CF6" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F0F5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#889098A8" />
        <SolidColorBrush x:Key="TextDimBrush" Color="#609098A8" />
        <SolidColorBrush x:Key="BubbleBgBrush" Color="#14FFFFFF" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Grid Grid.Column="0"
              BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,1,0">
            <ListView x:Name="MenuListView"
                      SelectionMode="Single"
                      SelectedIndex="0"
                      SelectionChanged="OnMenuSelectionChanged"
                      Background="Transparent"
                      Padding="0,16,0,0"
                      BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="Margin" Value="8,2" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="16"
                                  Foreground="{StaticResource AccentBlue}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="常规设置" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE71D;" FontSize="16"
                                  Foreground="{StaticResource IconGreen}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="启动台设置" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE765;" FontSize="16"
                                  Foreground="{StaticResource IconAmber}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="全局快捷键" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE94A;" FontSize="16"
                                  Foreground="#FF8B5CF6"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="AI 技能" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE916;" FontSize="16"
                                  Foreground="{StaticResource AccentBlue}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="小工具" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="16"
                                  Foreground="{StaticResource TextDimBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="关于" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                            </ListView>
        </Grid>

        <!-- Right content -->
        <Grid Grid.Column="1" Padding="24,24,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Dynamic header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock x:Name="TitleText"
                           Text="常规设置"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock x:Name="SubtitleText"
                           Text="设置应用程序的基本选项"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Opacity="0.7" />
            </StackPanel>

            <!-- ===== General panel ===== -->
            <StackPanel x:Name="GeneralPanel" Grid.Row="1" Spacing="16">
                <CheckBox Content="开机自启动"
                          IsChecked="{x:Bind ViewModel.IsAutoStart, Mode=TwoWay}"
                          FontSize="15" />
            </StackPanel>

            <!-- ===== Launchpad panel ===== -->
            <StackPanel x:Name="LaunchpadPanel" Grid.Row="1" Visibility="Collapsed" Spacing="8">

                <!-- Mouse triggers -->
                <TextBlock Text="鼠标触发" FontSize="14" FontWeight="SemiBold"
                           Margin="0,8,0,0" />
                <CheckBox Content="按下中键"
                          IsChecked="{x:Bind ViewModel.IsMouseTriggerMiddle, Mode=TwoWay}" />
                <CheckBox Content="按下X1键"
                          IsChecked="{x:Bind ViewModel.IsMouseTriggerX1, Mode=TwoWay}" />
                <CheckBox Content="按下X2键"
                          IsChecked="{x:Bind ViewModel.IsMouseTriggerX2, Mode=TwoWay}" />

                <!-- Keyboard triggers -->
                <TextBlock Text="键盘触发" FontSize="14" FontWeight="SemiBold"
                           Margin="0,8,0,0" />
                <CheckBox Content="单击Ctrl"
                          IsChecked="{x:Bind ViewModel.IsKeyboardTriggerSingleCtrl, Mode=TwoWay}" />
                <CheckBox Content="全局快捷键"
                          IsChecked="{x:Bind ViewModel.IsKeyboardTriggerGlobalHotKey, Mode=TwoWay}" />

                <!-- Hotkey display + modify button (visible when global hotkey is checked) -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="28,0,0,0"
                            Visibility="{x:Bind ViewModel.GlobalHotKeySettingsVisibility, Mode=OneWay}">
                    <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="12,4">
                        <TextBlock Text="{x:Bind ViewModel.LaunchpadHotKeyDisplay, Mode=OneWay}"
                                   FontSize="14" VerticalAlignment="Center" />
                    </Border>
                    <Button Content="修改" Click="OnModifyGlobalHotKeyClick"
                            Padding="12,4" CornerRadius="4" MinHeight="32" />
                </StackPanel>

                <CheckBox Content="Alt + 空格"
                          IsChecked="{x:Bind ViewModel.IsKeyboardTriggerAltSpace, Mode=TwoWay}" />

                <Button Content="打开启动台"
                        Click="OnOpenLaunchpadClick"
                        Padding="16,8" CornerRadius="6"
                        Margin="0,8,0,0" />
            </StackPanel>

            <!-- ===== Hotkey panel ===== -->
            <Grid x:Name="HotkeyPanel" Grid.Row="1" Visibility="Collapsed">
                <Grid>
                    <ListView x:Name="BindingListView"
                          SelectionMode="Single"
                          ItemsSource="{x:Bind ViewModel.Bindings, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:HotKeyBindingViewModel">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0"
                                       Width="36" Height="36"
                                       VerticalAlignment="Center"
                                       Source="{x:Bind IconSource, Mode=OneWay}"
                                       Tag="{x:Bind}"
                                       Loaded="OnIconImageLoaded" />

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{x:Bind Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind AppPath}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </Grid>

                                <Button Grid.Column="2"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.SetHotKeyCommand}"
                                        CommandParameter="{x:Bind}"
                                        MinWidth="110" MinHeight="32"
                                        VerticalAlignment="Center"
                                        Padding="12,4"
                                        CornerRadius="4">
                                    <TextBlock Text="{x:Bind HotKeyDisplayText, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="13" />
                                </Button>

                                <ToggleSwitch Grid.Column="3"
                                              IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                              VerticalAlignment="Center"
                                              Toggled="OnToggleToggled"
                                              Tag="{x:Bind}"
                                              MinWidth="50" />

                                <Button Grid.Column="4"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveBindingCommand}"
                                        CommandParameter="{x:Bind}"
                                        MinWidth="36" MinHeight="36"
                                        VerticalAlignment="Center"
                                        CornerRadius="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                    <StackPanel Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="12"
                                Padding="48,32">
                        <FontIcon Glyph="&#xE710;" FontSize="64" Opacity="0.5"
                                  Foreground="{StaticResource AccentBlue}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="还没有添加快捷键绑定"
                                   FontSize="18" Opacity="0.85"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text='点击下方 "添加应用程序" 按钮开始'
                                   FontSize="13" Opacity="0.5"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===== AI 技能 panel ===== -->
            <ScrollViewer x:Name="AIPanel" Grid.Row="1" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Margin="0,0,24,0">
                    <!-- API 配置区域 -->
                    <Border Background="#14FFFFFF" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="12">
                            <TextBlock Text="API 配置"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBox x:Name="AiApiKeyBox"
                                     Header="API Key"
                                     PlaceholderText="输入通义千问 API Key"
                                     TextChanged="OnAiConfigChanged"
                                     FontSize="14" />
                            <TextBox x:Name="AiEndpointBox"
                                     Header="Endpoint"
                                     PlaceholderText="https://dashscope.aliyuncs.com"
                                     TextChanged="OnAiConfigChanged"
                                     FontSize="14" />
                            <ComboBox x:Name="AiModelBox"
                                      Header="对话模型"
                                      SelectedIndex="0"
                                      FontSize="14">
                                <ComboBoxItem Content="qwen-plus" />
                                <ComboBoxItem Content="qwen-max" />
                                <ComboBoxItem Content="qwen-turbo" />
                                <ComboBoxItem Content="qwen-long" />
                            </ComboBox>
                            <TextBlock x:Name="AiConfigStatus"
                                       FontSize="12"
                                       Foreground="{StaticResource TextDimBrush}" />
                            <Button Content="测试连接"
                                    Click="OnTestAiConnection"
                                    Padding="16,6"
                                    CornerRadius="6"
                                    FontSize="13"
                                    HorizontalAlignment="Left"
                                    MinHeight="32" />
                        </StackPanel>
                    </Border>

                    <!-- 技能列表区域 -->
                    <Border Background="#14FFFFFF" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="已创建的技能"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="清空所有技能"
                                        Click="OnClearAllSkills"
                                        FontSize="12"
                                        Padding="10,4"
                                        CornerRadius="4"
                                        Background="#33FF4444"
                                        Foreground="#FFFF6B6B"
                                        BorderThickness="0" />
                            </Grid>
                            <StackPanel x:Name="SkillListStack" Spacing="6" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Tools panel ===== -->
            <Grid x:Name="ToolPanel" Grid.Row="1" Visibility="Collapsed">
                <!-- Tool list sub-view -->
                <ScrollViewer x:Name="ToolListPanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ToolListStack" Spacing="8" Margin="0,0,24,0" />
                </ScrollViewer>
                <!-- Tool settings sub-view (loaded dynamically) -->
                <Grid x:Name="ToolSettingsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button x:Name="ToolSettingsBackButton"
                            Content="← 返回工具列表"
                            Click="OnToolSettingsBack"
                            Background="Transparent"
                            Padding="0,0,0,12"
                            CornerRadius="4"
                            HorizontalAlignment="Left" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="ToolSettingsContent" />
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== About panel ===== -->
            <Grid x:Name="AboutPanel" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="0,0,24,0">
                        <Border Background="#14FFFFFF" CornerRadius="8" Padding="20,24">
                            <StackPanel Spacing="8">
                                <TextBlock Text="WinAssistant"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="VersionText"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Windows 效率工具合集，集成启动台、全局快捷键、AI 对话、小工具等功能。"
                                           FontSize="13"
                                           Foreground="{StaticResource TextDimBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="#14FFFFFF" CornerRadius="8" Padding="20,16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="技术栈"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text=".NET 9" />
                                    <Run Text="·" />
                                    <Run Text="WinUI 3" />
                                    <Run Text="·" />
                                    <Run Text="Windows App SDK 2.0" />
                                    <Run Text="·" />
                                    <Run Text="CommunityToolkit.Mvvm" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Add application button (only visible on hotkey tab) -->
            <Button x:Name="AddAppButton" Grid.Row="2"
                    Visibility="Collapsed"
                    Command="{x:Bind ViewModel.AddApplicationCommand}"
                    Margin="0,12,0,0"
                    Padding="16,8"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="添加应用程序" />
                </StackPanel>
            </Button>

        </Grid>
    </Grid>
</Page>
