<Page x:Class="WinAssistant.MainPage" x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:WinAssistant.ViewModels"
      Loaded="OnLoaded" Unloaded="OnUnloaded">
    <Page.Resources>
        <SolidColorBrush x:Key="ListViewItemDropIndicatorForeground"
                         Color="#30D9904A" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="全局快捷键管理"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="添加应用并设置全局快捷键"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Opacity="0.7" />
            </StackPanel>
            <Button Grid.Column="1" Click="OnSettingsClick"
                    VerticalAlignment="Center"
                    MinWidth="40" MinHeight="40" CornerRadius="6"
                    ToolTipService.ToolTip="设置">
                <FontIcon Glyph="&#xE713;" FontSize="16" />
            </Button>
        </Grid>

        <!-- ListView + empty state overlay -->
        <Grid Grid.Row="1">
            <ListView x:Name="BindingListView"
                  SelectionMode="Single"
                  CanDragItems="True"
                  AllowDrop="True"
                  CanReorderItems="True"
                  DragItemsStarting="OnDragItemsStarting"
                  DragItemsCompleted="OnDragItemsCompleted"
                  ItemsSource="{x:Bind ViewModel.Bindings, Mode=OneWay}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="56" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <RepositionThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:HotKeyBindingViewModel">
                    <Grid Padding="12,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0"
                               Width="36" Height="36"
                               VerticalAlignment="Center"
                               Source="{x:Bind IconSource, Mode=OneWay}"
                               Tag="{x:Bind}"
                               Loaded="OnIconImageLoaded" />

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind Name}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind AppPath}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.6"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Grid>

                        <Button Grid.Column="2"
                                Command="{Binding ElementName=RootPage, Path=ViewModel.SetHotKeyCommand}"
                                CommandParameter="{x:Bind}"
                                MinWidth="110" MinHeight="32"
                                VerticalAlignment="Center"
                                Padding="12,4"
                                CornerRadius="4">
                            <TextBlock Text="{x:Bind HotKeyDisplayText, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="13" />
                        </Button>

                        <ToggleSwitch Grid.Column="3"
                                      IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                      VerticalAlignment="Center"
                                      Toggled="OnToggleToggled"
                                      Tag="{x:Bind}"
                                      MinWidth="50" />

                        <Button Grid.Column="4"
                                Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveBindingCommand}"
                                CommandParameter="{x:Bind}"
                                MinWidth="36" MinHeight="36"
                                VerticalAlignment="Center"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

            <!-- Empty state -->
            <StackPanel Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="12"
                        Padding="48,32"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                <FontIcon Glyph="&#xE710;" FontSize="64" Opacity="0.5"
                          Foreground="{ThemeResource SystemAccentColor}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="还没有添加快捷键绑定"
                           FontSize="18" Opacity="0.85"
                           HorizontalAlignment="Center" />
                <TextBlock Text='点击下方 "添加应用程序" 按钮开始'
                           FontSize="13" Opacity="0.5"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Button Grid.Row="2"
                Command="{x:Bind ViewModel.AddApplicationCommand}"
                Margin="0,12,0,0"
                Padding="16,8"
                CornerRadius="6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE710;" FontSize="14" />
                <TextBlock Text="添加应用程序" />
            </StackPanel>
        </Button>

        <TextBlock Grid.Row="3"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Margin="0,8,0,0"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.5" />

    </Grid>
</Page>
