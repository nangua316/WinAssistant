<Page x:Class="WinAssistant.MainPage" x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:WinAssistant.ViewModels"
      xmlns:local="using:WinAssistant"
      Loaded="OnLoaded" Unloaded="OnUnloaded">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBgBrush" Color="#FBFBFD" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#EDEDF0" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1C1C1E" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E6E73" />
                    <SolidColorBrush x:Key="TextDimBrush" Color="#9E9EA2" />
                    <!-- Windows 系统强调色 — 跟随 Windows 设置变化 -->
                    <SolidColorBrush x:Key="AccentBlue" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="IconAmber" Color="{ThemeResource SystemAccentColorLight1}" />
                    <SolidColorBrush x:Key="PurpleBrush" Color="{ThemeResource SystemAccentColorDark1}" />
                    <SolidColorBrush x:Key="IconGreen" Color="{ThemeResource SystemAccentColorLight2}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBgBrush" Color="#262B3B" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#2E3447" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F0F5" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A8" />
                    <SolidColorBrush x:Key="TextDimBrush" Color="#7A7A80" />
                    <!-- Windows 系统强调色 — 跟随 Windows 设置变化 -->
                    <SolidColorBrush x:Key="AccentBlue" Color="{ThemeResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="IconAmber" Color="{ThemeResource SystemAccentColorLight1}" />
                    <SolidColorBrush x:Key="PurpleBrush" Color="{ThemeResource SystemAccentColorLight3}" />
                    <SolidColorBrush x:Key="IconGreen" Color="{ThemeResource SystemAccentColorLight2}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="ListViewItemDropIndicatorForeground"
                             Color="#30D47800" />

            <!-- Shared styles for code-behind-generated cards (ThemeResource ensures light/dark switching) -->
            <Style x:Key="ToolCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBgBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,12,16,12" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
            <Style x:Key="SkillCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBgBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="14,10,14,10" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Grid Grid.Column="0"
              BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,1,0">
            <ListView x:Name="MenuListView"
                      SelectionMode="Single"
                      SelectedIndex="0"
                      SelectionChanged="OnMenuSelectionChanged"
                      Background="Transparent"
                      Padding="0,16,0,0"
                      BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="Margin" Value="8,2" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="16"
                                  Foreground="{ThemeResource AccentBlue}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="常规设置" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE765;" FontSize="16"
                                  Foreground="{ThemeResource IconAmber}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="全局快捷键" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE94A;" FontSize="16"
                                  Foreground="{ThemeResource PurpleBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="AI 技能" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE916;" FontSize="16"
                                  Foreground="{ThemeResource AccentBlue}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="小工具" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE96C;" FontSize="16"
                                  Foreground="{ThemeResource IconGreen}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="输入法状态管理" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="16"
                                  Foreground="{ThemeResource TextDimBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="关于" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                            </ListView>
        </Grid>

        <!-- Right content -->
        <Grid Grid.Column="1" Padding="24,24,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Dynamic header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock x:Name="TitleText"
                           Text="常规设置"
                           Style="{ThemeResource TitleLargeTextBlockStyle}" />
                <TextBlock x:Name="SubtitleText"
                           Text="设置应用程序的基本选项"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Opacity="0.7" />
            </StackPanel>

            <!-- ===== General panel ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="GeneralPanel" Spacing="16" Margin="0,0,24,0">

                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0">
                        <Grid Padding="16,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE7FC;" FontSize="16"
                                      Foreground="{ThemeResource AccentBlue}"
                                      VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="开机自启动" FontSize="15" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2" MinWidth="48"
                                          IsOn="{x:Bind ViewModel.IsAutoStart, Mode=TwoWay}"
                                          OnContent="开" OffContent="关" />
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0">
                        <StackPanel>
                            <TextBlock Text="启动台" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       Padding="16,12,16,4" />

                            <!-- 鼠标触发 -->
                            <TextBlock Text="鼠标触发" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       Padding="16,8,16,0" />
                            <Grid Padding="16,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE962;" FontSize="16"
                                          Foreground="{ThemeResource AccentBlue}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="按下中键" FontSize="15"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="2" MinWidth="48"
                                              IsOn="{x:Bind ViewModel.IsMouseTriggerMiddle, Mode=TwoWay}"
                                              OnContent="开" OffContent="关" />
                            </Grid>
                            <Grid Padding="16,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE962;" FontSize="16"
                                          Foreground="{ThemeResource AccentBlue}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="按下X1键" FontSize="15"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="2" MinWidth="48"
                                              IsOn="{x:Bind ViewModel.IsMouseTriggerX1, Mode=TwoWay}"
                                              OnContent="开" OffContent="关" />
                            </Grid>
                            <Grid Padding="16,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE962;" FontSize="16"
                                          Foreground="{ThemeResource AccentBlue}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="按下X2键" FontSize="15"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="2" MinWidth="48"
                                              IsOn="{x:Bind ViewModel.IsMouseTriggerX2, Mode=TwoWay}"
                                              OnContent="开" OffContent="关" />
                            </Grid>

                            <!-- 键盘触发 -->
                            <TextBlock Text="键盘触发" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       Padding="16,12,16,0" />
                            <Grid Padding="16,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE765;" FontSize="16"
                                          Foreground="{ThemeResource IconAmber}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="全局快捷键" FontSize="15"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="{x:Bind ViewModel.LaunchpadHotKeyDisplay, Mode=OneWay}"
                                        Click="OnModifyGlobalHotKeyClick"
                                        FontSize="14"
                                        MinHeight="32" MinWidth="60"
                                        Padding="12,4"
                                        CornerRadius="4"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        Background="Transparent"
                                        Visibility="{x:Bind ViewModel.GlobalHotKeySettingsVisibility, Mode=OneWay}" />
                                <ToggleSwitch Grid.Column="3" MinWidth="48"
                                              IsOn="{x:Bind ViewModel.IsKeyboardTriggerGlobalHotKey, Mode=TwoWay}"
                                              OnContent="开" OffContent="关" />
                            </Grid>

                            <Grid Padding="16,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE765;" FontSize="16"
                                          Foreground="{ThemeResource IconAmber}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Alt + 空格" FontSize="15"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="2" MinWidth="48"
                                              IsOn="{x:Bind ViewModel.IsKeyboardTriggerAltSpace, Mode=TwoWay}"
                                              OnContent="开" OffContent="关" />
                            </Grid>

                            <Button Content="打开启动台"
                                    Click="OnOpenLaunchpadClick"
                                    Padding="16,8" CornerRadius="6"
                                    Margin="16,8,16,12"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Hotkey panel ===== -->
            <Grid x:Name="HotkeyPanel" Grid.Row="1" Visibility="Collapsed">
                <Grid>
                    <ListView x:Name="BindingListView"
                          SelectionMode="Single"
                          ItemsSource="{x:Bind ViewModel.Bindings, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:HotKeyBindingViewModel">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0"
                                       Width="36" Height="36"
                                       VerticalAlignment="Center"
                                       Source="{x:Bind IconSource, Mode=OneWay}"
                                       Tag="{x:Bind}"
                                       Loaded="OnIconImageLoaded" />

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{x:Bind Name}"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind AppPath}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </Grid>

                                <Button Grid.Column="2"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.SetHotKeyCommand}"
                                        CommandParameter="{x:Bind}"
                                        MinWidth="110" MinHeight="32"
                                        VerticalAlignment="Center"
                                        Padding="12,4"
                                        CornerRadius="4">
                                    <TextBlock Text="{x:Bind HotKeyDisplayText, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="13" />
                                </Button>

                                <ToggleSwitch Grid.Column="3"
                                              IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                              VerticalAlignment="Center"
                                              Toggled="OnToggleToggled"
                                              Tag="{x:Bind}"
                                              MinWidth="50" />

                                <Button Grid.Column="4"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveBindingCommand}"
                                        CommandParameter="{x:Bind}"
                                        MinWidth="36" MinHeight="36"
                                        VerticalAlignment="Center"
                                        CornerRadius="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                    <StackPanel Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="12"
                                Padding="48,32">
                        <FontIcon Glyph="&#xE710;" FontSize="64" Opacity="0.5"
                                  Foreground="{ThemeResource AccentBlue}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="还没有添加快捷键绑定"
                                   FontSize="18" Opacity="0.85"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text='点击下方 "添加应用程序" 按钮开始'
                                   FontSize="13" Opacity="0.5"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===== AI 技能 panel ===== -->
            <ScrollViewer x:Name="AIPanel" Grid.Row="1" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Margin="0,0,24,0">
                    <!-- API 配置区域 -->
                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="12">
                            <TextBlock Text="API 配置"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}" />
                            <TextBox x:Name="AiApiKeyBox"
                                     Header="API Key"
                                     PlaceholderText="输入通义千问 API Key"
                                     TextChanged="OnAiConfigChanged"
                                     FontSize="14" />
                            <TextBox x:Name="AiEndpointBox"
                                     Header="Endpoint"
                                     PlaceholderText="https://dashscope.aliyuncs.com"
                                     TextChanged="OnAiConfigChanged"
                                     FontSize="14" />
                            <ComboBox x:Name="AiModelBox"
                                      Header="对话模型"
                                      SelectedIndex="0"
                                      FontSize="14">
                                <ComboBoxItem Content="qwen-plus" />
                                <ComboBoxItem Content="qwen-max" />
                                <ComboBoxItem Content="qwen-turbo" />
                                <ComboBoxItem Content="qwen-long" />
                            </ComboBox>
                            <TextBlock x:Name="AiConfigStatus"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextDimBrush}" />
                            <Button Content="测试连接"
                                    Click="OnTestAiConnection"
                                    Padding="16,6"
                                    CornerRadius="6"
                                    FontSize="13"
                                    HorizontalAlignment="Left"
                                    MinHeight="32" />
                        </StackPanel>
                    </Border>

                    <!-- 技能列表区域 -->
                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="已创建的技能"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="清空所有技能"
                                        Click="OnClearAllSkills"
                                        FontSize="12"
                                        Padding="10,4"
                                        CornerRadius="4"
                                        Background="#33FF4444"
                                        Foreground="#FFFF6B6B"
                                        BorderThickness="0" />
                            </Grid>
                            <StackPanel x:Name="SkillListStack" Spacing="6" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Tools panel ===== -->
            <Grid x:Name="ToolPanel" Grid.Row="1" Visibility="Collapsed">
                <!-- Tool list sub-view -->
                <ScrollViewer x:Name="ToolListPanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ToolListStack" Spacing="8" Margin="0,0,24,0" />
                </ScrollViewer>
                <!-- Tool settings sub-view (loaded dynamically) -->
                <Grid x:Name="ToolSettingsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button x:Name="ToolSettingsBackButton"
                            Content="← 返回工具列表"
                            Click="OnToolSettingsBack"
                            Background="Transparent"
                            Padding="0,0,0,12"
                            CornerRadius="4"
                            HorizontalAlignment="Left" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="ToolSettingsContent" />
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== IME panel ===== -->
            <ScrollViewer x:Name="ImePanel" Grid.Row="1" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Margin="0,0,24,0">

                    <!-- 开关设置 -->
                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="12">
                            <TextBlock Text="开关设置"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontSize="16"
                                          Foreground="{ThemeResource IconAmber}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Toast 提示" FontSize="15"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch x:Name="ImeToastToggle" Grid.Column="2" MinWidth="48"
                                              Toggled="OnImeToastToggled"
                                              OnContent="开" OffContent="关" />
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE768;" FontSize="16"
                                          Foreground="{ThemeResource AccentBlue}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="按窗口自动切换输入法" FontSize="15"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch x:Name="ImeAutoSwitchToggle" Grid.Column="2" MinWidth="48"
                                              Toggled="OnImeAutoSwitchToggled"
                                              OnContent="开" OffContent="关" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 当前输入法状态 -->
                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="当前输入法状态"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="刷新"
                                        Click="OnImeRefreshStatus"
                                        FontSize="12" Padding="10,4"
                                        CornerRadius="4" MinHeight="28" />
                            </Grid>

                            <Border Background="#15FFFFFF" CornerRadius="6" Padding="14,10">
                                <StackPanel x:Name="ImeStatusStack" Spacing="6">
                                    <TextBlock x:Name="ImeStatusWindow"
                                               Text="当前窗口: —"
                                               FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock x:Name="ImeStatusLayout"
                                               Text="当前输入法: —"
                                               FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock x:Name="ImeStatusLang"
                                               Text="中/英: —"
                                               FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock x:Name="ImeStatusWidth"
                                               Text="全/半角: —"
                                               FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock x:Name="ImeStatusCaps"
                                               Text="大小写: —"
                                               FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock x:Name="ImeStatusMatched"
                                               Text="匹配规则: —"
                                               FontSize="13" Foreground="{ThemeResource AccentBlue}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 规则管理 -->
                    <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="规则管理"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="+ 添加规则"
                                        Click="OnImeAddRuleClick"
                                        FontSize="12" Padding="10,4"
                                        CornerRadius="4" MinHeight="28" />
                            </Grid>

                            <TextBlock x:Name="ImeEmptyState"
                                       Text="暂无规则，点击上方「添加规则」创建"
                                       FontSize="13" Opacity="0.5"
                                       Margin="0,8,0,0"
                                       Visibility="Visible" />

                            <!-- Rule list — code-generated UI -->
                            <StackPanel x:Name="ImeRuleStack"
                                        Visibility="Collapsed"
                                        Margin="0,4,0,0" />

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== About panel ===== -->
            <Grid x:Name="AboutPanel" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="0,0,24,0">
                        <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20,24">
                            <StackPanel Spacing="8">
                                <TextBlock Text="WinAssistant"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{ThemeResource TextPrimaryBrush}" />
                                <TextBlock x:Name="VersionText"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextSecondaryBrush}" />
                                <TextBlock Text="Windows 效率工具合集，集成启动台、全局快捷键、AI 对话、小工具等功能。"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextDimBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBgBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20,16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="技术栈"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}" />
                                <TextBlock FontSize="13"
                                           Foreground="{ThemeResource TextSecondaryBrush}">
                                    <Run Text=".NET 9" />
                                    <Run Text="·" />
                                    <Run Text="WinUI 3" />
                                    <Run Text="·" />
                                    <Run Text="Windows App SDK 2.0" />
                                    <Run Text="·" />
                                    <Run Text="CommunityToolkit.Mvvm" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Add application button (only visible on hotkey tab) -->
            <Button x:Name="AddAppButton" Grid.Row="2"
                    Visibility="Collapsed"
                    Command="{x:Bind ViewModel.AddApplicationCommand}"
                    Margin="0,12,0,0"
                    Padding="16,8"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="添加应用程序" />
                </StackPanel>
            </Button>

        </Grid>
    </Grid>
</Page>
