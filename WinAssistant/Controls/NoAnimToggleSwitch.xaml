<UserControl x:Class="WinAssistant.Controls.NoAnimToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="40" Height="20">
    <Grid Width="40" Height="20"
          VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- 轨道背景（关闭状态：灰色填充 + 描边） -->
        <Rectangle x:Name="_trackOff"
                   RadiusX="10" RadiusY="10"
                   Fill="{ThemeResource ControlAltFillColorSecondaryBrush}"
                   Stroke="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                   StrokeThickness="1" />
        <!-- 轨道填充（开启状态：主题色填充，无描边） -->
        <Rectangle x:Name="_trackOn"
                   RadiusX="10" RadiusY="10"
                   Fill="{ThemeResource AccentFillColorDefaultBrush}"
                   Opacity="0" />
        <!-- 滑块容器（20px 宽，通过 TranslateTransform 实现滑动动画） -->
        <Grid x:Name="_thumbContainer"
              Width="20" Height="20"
              HorizontalAlignment="Left">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="_thumbTranslate" />
            </Grid.RenderTransform>
            <!-- 关闭时的滑块（淡灰色） -->
            <Ellipse x:Name="_thumbOff"
                     Width="12" Height="12"
                     Fill="{ThemeResource TextFillColorSecondaryBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
            <!-- 开启时的滑块（白色） -->
            <Ellipse x:Name="_thumbOn"
                     Width="12" Height="12"
                     Fill="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="0" />
        </Grid>
    </Grid>
</UserControl>
