<Window x:Class="WinAssistant.Controls.AiChat.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 技能助手">
    <Grid x:Name="RootGrid" Background="#B00F1219">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid x:Name="TitleBar" Background="#14FFFFFF" Padding="16,12" />

        <!-- Message area -->
        <ScrollViewer x:Name="MessageScroll"
                      Grid.Row="1"
                      Padding="16,12,16,0"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled">
            <StackPanel x:Name="MessageStack" Spacing="8" />
        </ScrollViewer>

        <!-- Input area -->
        <Border x:Name="InputBar" Grid.Row="2" Background="#14FFFFFF" Padding="12,8,12,16" />
    </Grid>
</Window>
