<Window
    x:Class="WinAssistant.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinAssistant"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WinAssistant - 设置"
    mc:Ignorable="d">

    <!-- MicaBackdrop 已移除：它与 RequestedTheme 切换存在兼容性问题（见 microsoft-ui-xaml #5886）-->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="WinAssistant - 设置">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- Launchpad overlay — covers everything including title bar -->
        <Grid x:Name="LaunchpadOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="{ThemeResource LaunchpadBgBrush}" />
    </Grid>
</Window>
